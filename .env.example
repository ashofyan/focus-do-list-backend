APP_NAME="Todo Manager"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# ============================================================
# DATABASE - PostgreSQL
# ============================================================
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=todo_db
DB_USERNAME=postgres
DB_PASSWORD=your_password

# ============================================================
# QUEUE
# ============================================================
QUEUE_CONNECTION=database

# ============================================================
# CACHE
# ============================================================
CACHE_STORE=database
CACHE_PREFIX=todo_cache

# ============================================================
# SESSION
# ============================================================
SESSION_DRIVER=database
SESSION_LIFETIME=120

# ============================================================
# MAIL (opsional, untuk fitur nanti)
# ============================================================
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@todoapp.com"
MAIL_FROM_NAME="${APP_NAME}"
